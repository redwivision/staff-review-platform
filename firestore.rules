rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is a Team Leader
    function isLeader() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isLeader == true;
    }

    // Helper function to check if the user is an Admin
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == "lewikb13@gmail.com"
      );
    }
    
    // Helper function to check if resource belongs to the user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // Rules for Development Reviews
    match /developmentReviews/{reviewId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isLeader());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isLeader());
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isLeader());
    }

    // Rules for Quarterly Summaries
    match /quarterlySummaries/{summaryId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isLeader());
      allow write: if isLeader(); // Only leaders can create/update/delete quarterly summaries
    }

    // Rules for Activity Logs
    match /activityLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (isLeader() || resource.data.userId == request.auth.uid);
      allow delete: if isLeader();
    }

    // Rules for Follow-Up Tasks
    match /followUpTasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Requirement Settings
    match /requirementSettings/{settingsId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Meetings
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow write: if isLeader();
    }

    // Rules for Coaching Requests
    match /coachingRequests/{requestId} {
      allow read, write: if isAuthenticated();
    }
  }
}
